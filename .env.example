# ╔══════════════════════════════════════════════════════════════════════╗
# ║  HRBot Environment Variables                                        ║
# ║  Copy to .env and fill in real values. NEVER commit .env to Git.    ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ─── BACKEND (Core) ─────────────────────────────────────────────────

# Anthropic Claude API Key (required for LLM; fallback mode if missing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server config
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Trusted Hosts — comma-separated (prevents host-header attacks)
ALLOWED_HOSTS=localhost,127.0.0.1

# Authentication mode
# Set to "true" in production to enforce Firebase JWT verification
# Set to "false" during local dev / demo to allow unauthenticated access
AUTH_REQUIRED=false

# Firebase service account (production only)
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# API docs visibility (disable in production)
ENABLE_DOCS=true

# ─── STRATEGY #1: SUPABASE BaaS ─────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
# Leave blank to use in-memory storage (demo-safe)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ─── STRATEGY #3: TWILIO SMS ────────────────────────────────────────
# Leave blank to disable SMS notifications (they'll log to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890
HR_PHONE_NUMBER=+1234567890

# ─── STRATEGY #3: SLACK WEBHOOK ─────────────────────────────────────
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ─── STRATEGY #3: SENDGRID EMAIL ────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hrbot@company.com

# ─── FRONTEND ────────────────────────────────────────────────────────

# Vite backend URL
VITE_API_BASE_URL=http://localhost:8000

# Firebase Auth Configuration (managed auth — Strategy #1)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
